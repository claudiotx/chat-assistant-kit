OPENAI_API_KEY=your_key_here
PORT=8000

# Generate with: openssl rand -hex 32
JWT_SECRET=replace_me_with_a_random_secret

# Demo login credentials for POST /api/auth/login.
# A real deployment can delete src/auth/router.ts entirely and issue its own
# JWTs signed with JWT_SECRET, using the same {sub, sessionId} claims shape.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme

# Comma-separated allowlist of models callers may request.
ALLOWED_MODELS=gpt-4o-mini,gpt-4o

# Comma-separated allowlist of frontend origins allowed to call this API.
CORS_ORIGIN=http://localhost:5173

# Optional LLM observability via Langfuse (https://cloud.langfuse.com). Off by
# default — nothing below is required unless you set AI_TELEMETRY_ENABLED=true.
AI_TELEMETRY_ENABLED=false
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
# Only needed for a self-hosted Langfuse instance; omit to use Langfuse Cloud.
LANGFUSE_BASE_URL=
# Off by default: logs prompt/response content to Langfuse. Only enable if
# you're comfortable with that data leaving this server.
AI_TELEMETRY_RECORD_IO=false

# Optional local AI SDK DevTools inspector. Off by default, and refused
# outside development regardless of this flag. Run `npx @ai-sdk/devtools` and
# open http://localhost:4983 once enabled.
AI_DEVTOOLS_ENABLED=false
